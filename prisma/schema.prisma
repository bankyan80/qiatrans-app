generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ============================================
// ENUMS (using String and enforce in app logic)
// ============================================

// User roles: OWNER, ADMIN, DRIVER, CUSTOMER
// Vehicle categories: SUV, SEDAN, MPV, HATCHBACK, VAN, PICKUP, LUXURY
// Vehicle statuses: AVAILABLE, RENTED, MAINTENANCE, OUT_OF_SERVICE
// Booking statuses: PENDING, CONFIRMED, ACTIVE, COMPLETED, CANCELLED
// Payment methods: QRIS, BANK_TRANSFER, E_WALLET, CASH
// Payment statuses: PENDING, SUCCESS, FAILED, REFUNDED
// Document types: CONTRACT, TRAVEL_PERMIT, CHECKLIST
// Maintenance types: SERVICE, REPAIR, INSURANCE, TAX, STNK
// Maintenance statuses: SCHEDULED, IN_PROGRESS, COMPLETED, OVERDUE
// Notification types: BOOKING, PAYMENT, MAINTENANCE, PROMO
// Driver statuses: ONLINE, OFFLINE, BUSY

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  password  String
  role      String   @default("CUSTOMER") // OWNER, ADMIN, DRIVER, CUSTOMER
  idNumber  String?
  avatar    String?
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings        Booking[]       @relation("CustomerBookings")
  driverBookings  Booking[]       @relation("DriverBookings")
  driver          Driver?
  reviews         Review[]
  notifications   Notification[]

  @@index([email])
  @@index([role])
}

model Vehicle {
  id          String   @id @default(cuid())
  brand       String
  model       String
  year        Int
  color       String?
  plateNumber String   @unique
  category    String   // SUV, SEDAN, MPV, HATCHBACK, VAN, PICKUP, LUXURY
  dailyRate   Float
  weeklyRate  Float?
  monthlyRate Float?
  status      String   @default("AVAILABLE") // AVAILABLE, RENTED, MAINTENANCE, OUT_OF_SERVICE
  fuelType    String?  // BENSIN, DIESEL, HYBRID, ELECTRIC
  transmission String? // MANUAL, AUTOMATIC, CVT
  seats       Int      @default(5)
  imageUrl    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  bookings     Booking[]
  maintenance  Maintenance[]
  trackingLogs TrackingLog[]

  @@index([status])
  @@index([category])
  @@index([brand])
}

model Booking {
  id             String   @id @default(cuid())
  customerId     String
  vehicleId      String
  driverId       String?
  startDate      DateTime
  endDate        DateTime
  totalPrice     Float
  status         String   @default("PENDING") // PENDING, CONFIRMED, ACTIVE, COMPLETED, CANCELLED
  withDriver     Boolean  @default(false)
  pickupLocation String?
  returnLocation String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  customer     User       @relation("CustomerBookings", fields: [customerId], references: [id])
  vehicle      Vehicle    @relation(fields: [vehicleId], references: [id])
  driver       User?      @relation("DriverBookings", fields: [driverId], references: [id])
  payments     Payment[]
  documents    Document[]
  reviews      Review[]

  @@index([customerId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model Driver {
  id            String    @id @default(cuid())
  userId        String    @unique
  licenseNumber String
  licenseExpiry DateTime
  licenseImage  String?
  address       String?
  status        String    @default("OFFLINE") // ONLINE, OFFLINE, BUSY
  rating        Float     @default(0.0)
  totalTrips    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model Payment {
  id             String    @id @default(cuid())
  bookingId      String
  amount         Float
  method         String    // QRIS, BANK_TRANSFER, E_WALLET, CASH
  status         String    @default("PENDING") // PENDING, SUCCESS, FAILED, REFUNDED
  isDownPayment  Boolean   @default(false)
  transactionId  String?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
}

model Document {
  id               String   @id @default(cuid())
  bookingId        String
  type             String   // CONTRACT, TRAVEL_PERMIT, CHECKLIST
  content          String?  // JSON string
  digitalSignature String?
  createdAt        DateTime @default(now())

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([type])
}

model Maintenance {
  id           String    @id @default(cuid())
  vehicleId    String
  type         String    // SERVICE, REPAIR, INSURANCE, TAX, STNK
  description  String?
  cost         Float     @default(0.0)
  dueDate      DateTime?
  completedDate DateTime?
  status       String    @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, OVERDUE
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([status])
  @@index([dueDate])
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  customerId String
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  // Relations
  booking  Booking @relation(fields: [bookingId], references: [id])
  customer User    @relation(fields: [customerId], references: [id])

  @@index([bookingId])
  @@index([customerId])
  @@index([rating])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // BOOKING, PAYMENT, MAINTENANCE, PROMO
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([type])
}

model TrackingLog {
  id        String   @id @default(cuid())
  vehicleId String
  latitude  Float
  longitude Float
  speed     Float    @default(0.0)
  timestamp DateTime @default(now())

  // Relations
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([timestamp])
}
